# ClashCommand / CoC Report local configuration.
# Copy to .env locally or create /opt/clashcommand/.env on the droplet.
# Never commit real token values.

# Required for the Discord bot.
DISCORD_BOT_TOKEN=
CLASH_API_TOKEN=
CLAN_TAG="#22YY2LPV2"

# Existing static scripts still use these names.
COC_API_TOKEN=
COC_CLAN_TAG="#22YY2LPV2"

# Recommended during MVP so slash commands sync instantly to your test server.
DISCORD_TEST_GUILD_ID=
COMMAND_SYNC_MODE=guild

# Bot runtime data. SQLite first, Postgres-compatible design later.
DATABASE_URL=sqlite:///data/clashcommand.sqlite3
CLASHCOMMAND_DATA_DIR=data

# Display and logging defaults.
DEFAULT_TIMEZONE=America/Chicago
LOG_LEVEL=INFO
ENVIRONMENT=development

# Existing scheduler/report options.
WAR_END_BUFFER_MINUTES=2
WAR_PREP_POLL_MINUTES=30
WAR_IDLE_POLL_MINUTES=60
WAR_ENDED_POLL_MINUTES=30
WAR_RESULTS_DIR=data/war_results
REPORT_DAYS=7
WAR_WARNING_TARGET_HOURS=3
WAR_WARNING_INCLUDE_COUNTS=true
